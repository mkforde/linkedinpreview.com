# Required
NEXT_PUBLIC_GTM_MEASUREMENT_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_POSTHOG_KEY="phc_XXXXXXXXXX"

# Optional - Tally.so feedback form (leave empty to disable)
NEXT_PUBLIC_TALLY_FORM_ID=""

# Required - Supabase (anonymous auth + rate limiting)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Required - OpenAI-compatible LLM (used for AI post generation)
LLM_API_KEY="sk-..."
# Optional - model ID. Defaults to gpt-4o-mini. For Claude via the Anthropic
# OpenAI-compatible endpoint, use e.g. claude-sonnet-5 or claude-opus-4-8.
LLM_MODEL=""
# Optional - base URL of an OpenAI-compatible endpoint. Leave empty for OpenAI.
# For Claude (Anthropic OpenAI-compatible API):
# LLM_BASE_URL="https://api.anthropic.com/v1"
LLM_BASE_URL=""

# Optional - lock the AI endpoints to yourself on a public deployment.
# When set, the AI features require an unlock cookie: visit
#   https://your-domain/api/ai-unlock?token=<this value>
# once in your browser. Leave empty to keep the AI endpoints open to everyone.
AI_ACCESS_TOKEN=""
